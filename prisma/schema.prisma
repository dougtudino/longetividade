generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id              String    @id @default(uuid())
  email           String
  name            String
  phone           String?
  plan            String    // "basico" | "completo" | "vip"
  amount          Int       // em centavos
  status          String    @default("pending") // pending | approved | rejected
  mpPaymentId     String?   @unique
  mpPreferenceId  String?   @unique
  downloadToken   String?   @unique
  downloadCount   Int       @default(0)
  tokenExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([downloadToken])
  @@index([createdAt])
}

model AbandonedCheckout {
  id        String   @id @default(uuid())
  email     String
  plan      String?
  step      String   @default("checkout")
  createdAt DateTime @default(now())

  @@index([email])
}

model Campaign {
  id        String    @id @default(uuid())
  name      String
  platform  String    // "meta" | "google" | "organic" | "email"
  objective String    // "conversao" | "trafego" | "awareness"
  status    String    @default("active") // active | paused | finished
  budget    Float     // orçamento diário R$
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  metrics   CampaignMetric[]
}

model CampaignMetric {
  id          String   @id @default(uuid())
  campaignId  String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model PageView {
  id           String   @id @default(uuid())
  page         String
  referrer     String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  country      String?
  device       String?
  createdAt    DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([utm_source])
}

// ─── App VIP ───────────────────────────────────────

model AppUser {
  id         String   @id @default(uuid())
  email      String   @unique
  orderId    String   @unique
  plan       String   // "vip"
  accessType String   @default("lifetime") // "lifetime" | "subscription"
  createdAt  DateTime @default(now())

  profile    AppProfile?
  checkins   AppCheckin[]
  waterLogs  AppWaterLog[]
  weightLogs AppWeightLog[]

  @@index([email])
}

model AppProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  name           String
  objective      String   // "emagrecer" | "habitos" | "ambos"
  currentWeight  Float?
  height         Float?
  age            Int?
  goalType       String   // "primeiro_kg" | "5kg" | "10kg" | "peso_ideal" | "custom"
  goalCustom     String?
  goalWeight     Float?
  challenges     String[]
  onboardingDone Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           AppUser  @relation(fields: [userId], references: [id])
}

model AppCheckin {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  habits       Json     // { agua: bool, refeicoes: bool, fruta: bool, ... }
  waterCount   Int      @default(0)
  exerciseDone Boolean  @default(false)
  exerciseMin  Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  user         AppUser  @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AppWaterLog {
  id       String   @id @default(uuid())
  userId   String
  cups     Int
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppWeightLog {
  id       String   @id @default(uuid())
  userId   String
  weight   Float
  note     String?
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppVipSlot {
  id         String   @id @default("singleton")
  totalSlots Int      @default(100)
  usedSlots  Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
