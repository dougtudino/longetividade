generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                    String    @id @default(uuid())
  email                 String
  name                  String
  phone                 String?
  plan                  String    // "basico" | "completo" | "vip"
  amount                Int       // em centavos
  status                String    @default("pending") // pending | approved | refunded | canceled | chargeback
  mpPaymentId           String?   @unique
  mpPreferenceId        String?   @unique
  hotmartTransactionId  String?   @unique // ID Hotmart (HP...) — source of truth
  downloadToken         String?   @unique
  downloadCount         Int       @default(0)
  tokenExpiresAt        DateTime?
  syncedFromApiAt       DateTime? // quando foi reconciliada via Hotmart Sales API
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([downloadToken])
  @@index([createdAt])
}

model AbandonedCheckout {
  id        String   @id @default(uuid())
  email     String
  plan      String?
  step      String   @default("checkout")
  createdAt DateTime @default(now())

  @@index([email])
}

model Lead {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  source       String?   // utm_source
  sequenceStep Int       @default(0) // 0=welcome enviado, 1=D+2 enviado, 2=D+5 enviado, -1=opt-out
  lastEmailAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sequenceStep])
  @@index([createdAt])
}

// ─── Creatives — Collections & Gallery ─────────────────

model CreativeCollection {
  id          String     @id @default(uuid())
  slug        String     @unique
  name        String
  description String?
  icon        String?    // emoji
  campaignId  String?    // opcional: liga a uma Campaign local
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  creatives   Creative[]

  @@index([createdAt])
}

model Creative {
  id           String    @id @default(uuid())
  collectionId String
  slug         String    // identificador unico dentro da colecao (ex: "feed-dor")
  componentKey String    // mapeia para CREATIVES_REGISTRY (registry.ts) ou "ai:<templateId>" se gerado por IA
  name         String
  format       String    // "feed" | "story" | "banner" | "custom"
  width        Int
  height       Int
  description  String?
  tags         String[]  @default([])
  metaImageHash String?  // hash da imagem na Meta /adimages (se uploaded)
  imageUrl     String?   // URL publica (CDN Blotato) pra creatives AI
  aiGenerated  Boolean   @default(false) // true se gerado via Uma+Blotato
  archived     Boolean   @default(false) // soft-archive: nao usar em novos ads, mas preserva historico
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  collection   CreativeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  copies       CreativeCopy[]

  @@unique([collectionId, slug])
  @@index([collectionId])
  @@index([format])
  @@index([archived])
}

// Variacoes de texto para A/B testing — cada Creative (visual) pode ter
// varias copies (headline + description + cta) pra testar performance.
// Meta Ads permite rodar mesmo visual com copies diferentes em adsets distintos.
model CreativeCopy {
  id          String   @id @default(uuid())
  creativeId  String
  label       String   // "A", "B", "controle", "variante-dor"
  headline    String
  description String?  @db.Text
  cta         String?  // "Saiba mais" | "Comprar agora" | "Inscreva-se"
  primaryText String?  @db.Text // texto principal Meta (acima do visual)
  // metricas agregadas (sincronizadas pelo cron sync-meta-ads)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spendCents  Int      @default(0)
  conversions Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creative    Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@unique([creativeId, label])
  @@index([creativeId])
  @@index([active])
}

// ─── Social Media — Posts & Calendar ───────────────────

model SocialPost {
  id           String    @id @default(uuid())
  title        String
  content      String    @db.Text // copy/legenda do post
  platform     String    // "instagram" | "facebook" | "stories" | "reels" | "tiktok"
  format       String    // "carrossel" | "imagem" | "reels" | "stories" | "texto"
  pillar       String    // "s" | "e" | "m" | "promo"
  hashtags     String?   @db.Text
  imageUrl     String?   // URL do criativo (se tiver)
  imageBriefing String?  @db.Text // briefing pra Uma criar o visual
  slot         String    @default("FEED_AM") // FEED_AM | REEL | STORY — slot de conteudo
  status       String    @default("draft") // draft | review | approved | posted | rejected
  reviewNote   String?   // nota do QA
  scheduledAt  DateTime? // quando postar
  postedAt     DateTime?
  engagementData Json?   // { likes, comments, shares, reach, saves }
  createdBy    String?   // admin que criou
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  images       SocialPostImage[]

  @@index([status])
  @@index([platform])
  @@index([pillar])
  @@index([slot])
  @@index([scheduledAt])
  @@index([createdAt])
}

// PNGs renderizados de cada post/slide. Servidos via rota publica
// /api/public/social-image/[postId]/[slide].png pra Meta Graph buscar.
model SocialPostImage {
  id         String     @id @default(uuid())
  postId     String
  slideIndex Int        @default(0) // 0 = unica/cover; 1,2,3... = carrossel
  mimeType   String     @default("image/png")
  data       Bytes
  width      Int?
  height     Int?
  createdAt  DateTime   @default(now())
  post       SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, slideIndex])
  @@index([postId])
}

// ─── AIOX Agents — Knowledge & Decisions ───────────────

model AgentKnowledge {
  id        String   @id @default(uuid())
  agentId   String   // "gaia" | "maya" | "uma" | "alex" | ...
  kind      String   // "fact" | "rule" | "benchmark" | "reference" | "learning" | "policy"
  title     String
  body      String   @db.Text
  source    String?  // where it came from (manual, gaia-persona, meta-docs, blog-url, etc)
  metadata  Json?    // optional structured data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([kind])
  @@index([createdAt])
}

model AgentDecision {
  id          String   @id @default(uuid())
  agentId     String   // who proposed
  action      String   // "PAUSE_ADSET" | "DUPLICATE_ADSET" | "INCREASE_BUDGET" | "DECREASE_BUDGET" | "ACTIVATE_ADSET"
  targetType  String   // "adset" | "campaign" | "ad" | "creative"
  targetId    String   // Meta ID
  targetName  String   // human-readable
  params      Json     // action params (e.g. { budget_cents: 3600, reason: "..." })
  reasoning   String   @db.Text
  priority    String   @default("normal") // "low" | "normal" | "high" | "critical"
  status      String   @default("proposed") // "proposed" | "approved" | "executed" | "rejected" | "failed"
  // progressStatus eh ortogonal a status: controla a posicao do card nas
  // tabs do painel Gaia (proposed | in_progress | completed | archived).
  // Usado principalmente por DIAGNOSE_FUNNEL/PROPOSE_ITERATION pra fluxo
  // de checklist acionavel. Default proposed pra rows existentes.
  progressStatus String @default("proposed")
  approvedBy  String?  // admin email who approved
  approvedAt  DateTime?
  executedAt  DateTime?
  executionResult Json?
  rejectedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklistItems DecisionChecklistItem[]

  @@index([agentId])
  @@index([status])
  @@index([progressStatus])
  @@index([createdAt])
}

// Itens de checklist gerados a partir de uma AgentDecision (DIAGNOSE_FUNNEL,
// PROPOSE_ITERATION). Cada item tem agentes AIOX atribuidos e pode ser
// aprovado/pulado individualmente. Em Sprint 2, approve dispara o agente
// real; em Sprint 1, gera apenas um doc placeholder em docs/checklist-items/.
model DecisionChecklistItem {
  id             String   @id @default(cuid())
  decisionId     String
  decision       AgentDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  orderIndex     Int
  title          String
  description    String   @db.Text
  assignedAgents String[] // ['morgan', 'uma-creative', 'dex']
  status         String   @default("pending") // pending | approved | in_progress | done | skipped
  approvedAt     DateTime?
  completedAt    DateTime?
  artifactPath   String?  // caminho do doc gerado ou URL do PR
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([decisionId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────
// Launch Blueprint — documento mestre editavel de uma campanha Meta
// Substitui o blueprint TypeScript hardcoded (lib/blueprints/launch-001.ts
// — DEPRECATED). Admin edita na UI /admin/campanhas/launch-blueprint.
// ─────────────────────────────────────────────────────────────────────
model LaunchBlueprint {
  id                String   @id @default(cuid())
  launchId          String   @unique                 // "LAUNCH-001"
  name              String                           // "LAUNCH-001-Pioneer"
  status            String   @default("draft")       // draft | ready | launched | paused | archived

  productName       String
  productPriceBrl   Int
  productHotmartId  String?
  landingUrl        String
  pixelId           String
  datasetName       String                           // "Dados de Longetividade"
  adAccountId       String                           // "act_837047967961012"
  businessManagerId String

  campaignName      String                           // "LONG-AQ-01-Conversao-Pioneer-Mar2026"
  campaignObjective String   @default("OUTCOME_SALES")
  budgetTotalBrl    Int                              // R$95/dia (somatorio esperado)
  advantageBudget   Boolean  @default(false)

  metaCampaignId    String?                          // preenchido apos launch
  launchedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  audiences         LaunchAudience[]
  adSets            LaunchAdSet[]

  @@index([status])
  @@index([createdAt])
}

model LaunchAudience {
  id                 String   @id @default(cuid())
  blueprintId        String
  blueprint          LaunchBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  orderIndex         Int

  audienceKey        String                          // "ca_compradores" | "lal_1pct_pageview_30d"
  audienceType       String                          // "website_event" | "lookalike"
  eventName          String?                         // "Purchase" | "PageView" | "InitiateCheckout" | "Lead"
  retentionDays      Int?

  lookalikeSourceKey String?                         // referencia outra audience (pra source do lookalike)
  lookalikeCountry   String?                         // "BR"
  lookalikeRatio     Float?                          // 0.01 (1%)

  metaAudienceId     String?                         // preenchido apos criar no Meta
  status             String   @default("pending")    // pending | operational | processing | failed
  statusMessage      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([blueprintId, audienceKey])
  @@index([blueprintId])
  @@index([status])
}

model LaunchAdSet {
  id                    String   @id @default(cuid())
  blueprintId           String
  blueprint             LaunchBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  orderIndex            Int

  adSetKey              String                       // "ASET-01-Cold-Interesses-3050"
  layer                 String                       // "cold" | "warm" | "hot"
  activateOn            String                       // "day_1" | "day_5" | "manual"

  budgetDailyBrl        Int                          // 25

  ageMin                Int
  ageMax                Int
  genders               String[]                     // ["female"] | ["male"] | ["female", "male"]
  countries             String[]                     // ["BR"]

  interests             Json?                        // [{ id: "6003107902433", name: "Emagrecimento" }]
  behaviors             Json?                        // [{ id: "...", name: "..." }]

  customAudienceKeys    String[]                     // ["lal_1pct_pageview_30d"]
  excludedAudienceKeys  String[]                     // ["ca_compradores"]

  optimizationGoal      String   @default("OFFSITE_CONVERSIONS")
  promotedObjectEvent   String   @default("PURCHASE")

  creativesCollectionId String?                      // slug da CreativeCollection (ex: "launch-001-pioneer")
  creativesAngles       String[]                     // ["dor", "prova", "objecao", "promessa", "cta"]
  numAds                Int                          // 5

  metaAdSetId           String?
  status                String   @default("pending") // pending | created | failed
  statusMessage         String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([blueprintId, adSetKey])
  @@index([blueprintId])
  @@index([layer])
  @@index([status])
}

model Campaign {
  id              String    @id @default(uuid())
  name            String
  platform        String    // "meta" | "google" | "organic" | "email"
  objective       String    // "conversao" | "trafego" | "awareness"
  status          String    @default("active") // active | paused | finished
  budget          Float     // orçamento diário R$
  startDate       DateTime
  endDate         DateTime?
  notes           String?
  metaCampaignId  String?   @unique // ID da campanha no Meta (act_xxx/campaigns)
  lastSyncedAt    DateTime?
  // source distingue origem da campanha pro admin filtrar:
  // - blueprint: criada via launcher do LaunchBlueprint (sistema novo, oficial)
  // - legacy: criada via UI antiga "+ Nova campanha" (DEPRECATED 2026-04-20)
  // - synced: vinda do sync-meta-ads sem LaunchBlueprint correspondente
  //   (campanha criada manualmente no Meta Ads Manager, fora do sistema)
  source          String    @default("legacy")
  // Liga campanha local ao LaunchBlueprint que a originou (apenas
  // pra source=blueprint). Permite navegar Campaign -> Blueprint na UI.
  launchId        String?   // ref LaunchBlueprint.launchId (string, nao FK)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  metrics         CampaignMetric[]

  @@index([source])
  @@index([launchId])
}

model CampaignMetric {
  id          String   @id @default(uuid())
  campaignId  String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model PageView {
  id           String   @id @default(uuid())
  page         String
  referrer     String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  country      String?
  device       String?
  createdAt    DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([utm_source])
}

// ─── App VIP ───────────────────────────────────────

model AppUser {
  id           String   @id @default(uuid())
  email        String   @unique
  orderId      String   @unique
  plan         String   // "vip"
  accessType   String   @default("lifetime") // "lifetime" | "subscription"
  passwordHash String?  // bcrypt hash (null se login via email-only ou Google)
  googleId     String?  @unique // Google sub ID para OAuth
  createdAt    DateTime @default(now())

  profile         AppProfile?
  checkins        AppCheckin[]
  waterLogs       AppWaterLog[]
  weightLogs      AppWeightLog[]
  moodLogs        AppMoodLog[]
  achievements    AppUserAchievement[]
  level           AppUserLevel?
  favoriteRecipes AppFavoriteRecipe[]
  challenges      AppChallenge[]
  measurements    AppMeasurement[]

  @@index([email])
}

model AppProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  name           String
  objective      String   // "emagrecer" | "habitos" | "ambos"
  currentWeight  Float?
  height         Float?
  age            Int?
  goalType       String   // "primeiro_kg" | "5kg" | "10kg" | "peso_ideal" | "custom"
  goalCustom     String?
  goalWeight     Float?
  challenges     String[]
  onboardingDone Boolean  @default(false)
  waterGoal      Int      @default(8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           AppUser  @relation(fields: [userId], references: [id])
}

model AppCheckin {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  habits       Json     // { agua: bool, refeicoes: bool, fruta: bool, ... }
  waterCount   Int      @default(0)
  exerciseDone Boolean  @default(false)
  exerciseMin  Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  user         AppUser  @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AppWaterLog {
  id       String   @id @default(uuid())
  userId   String
  cups     Int
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppWeightLog {
  id       String   @id @default(uuid())
  userId   String
  weight   Float
  note     String?
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppVipSlot {
  id         String   @id @default("singleton")
  totalSlots Int      @default(100)
  usedSlots  Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── App VIP Sprint 2 ─────────────────────────────

model AppMoodLog {
  id        String   @id @default(uuid())
  userId    String
  mood      String
  note      String?
  triggers  String[]
  loggedAt  DateTime @default(now())
  user      AppUser  @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([loggedAt])
}

model AppAchievement {
  id               String   @id
  name             String
  description      String
  icon             String
  category         String
  condition        String
  xp               Int      @default(10)
  userAchievements AppUserAchievement[]
}

model AppUserAchievement {
  id            String         @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime       @default(now())
  user          AppUser        @relation(fields: [userId], references: [id])
  achievement   AppAchievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@index([userId])
}

model AppUserLevel {
  id        String   @id @default(uuid())
  userId    String   @unique
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
  user      AppUser  @relation(fields: [userId], references: [id])
}

model AppRecipe {
  id          String   @id @default(uuid())
  name        String
  category    String
  pillar      String
  prepTime    Int
  serves      Int
  ingredients String[]
  steps       String[]
  tip         String
  createdAt   DateTime @default(now())
  favorites   AppFavoriteRecipe[]
}

model AppFavoriteRecipe {
  id        String    @id @default(uuid())
  userId    String
  recipeId  String
  createdAt DateTime  @default(now())
  user      AppUser   @relation(fields: [userId], references: [id])
  recipe    AppRecipe @relation(fields: [recipeId], references: [id])
  @@unique([userId, recipeId])
}

model AppChallenge {
  id          String   @id @default(uuid())
  userId      String
  day         Int
  completedAt DateTime @default(now())
  user        AppUser  @relation(fields: [userId], references: [id])
  @@unique([userId, day])
  @@index([userId])
}

model AppMeasurement {
  id        String   @id @default(uuid())
  userId    String
  waist     Float?
  hip       Float?
  note      String?
  loggedAt  DateTime @default(now())
  user      AppUser  @relation(fields: [userId], references: [id])
  @@index([userId])
}

// ─── Admin Multi-User ─────────────────────────────

model AdminUser {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  passwordHash String
  googleId     String?       @unique // Google sub ID para OAuth
  role         String        @default("manager")
  inviteToken  String?       @unique
  inviteUsed   Boolean       @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  mayaMessages MayaMessage[]
}

model MayaMessage {
  id        String    @id @default(uuid())
  adminId   String
  role      String
  content   String    @db.Text
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id])
  @@index([adminId])
  @@index([createdAt])
}

// ─── Video Intelligence ──────────────────────────────
model VideoCompetitor {
  id          String   @id @default(uuid())
  username    String   @unique
  category    String   @default("longetividade")
  followers   Int      @default(0)
  avgViews30d Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  analyses    VideoAnalysis[]

  @@index([active])
}

model VideoAnalysis {
  id           String          @id @default(uuid())
  competitorId String
  competitor   VideoCompetitor @relation(fields: [competitorId], references: [id])
  instagramUrl String
  thumbnail    String          @default("")
  views        Int             @default(0)
  likes        Int             @default(0)
  comments     Int             @default(0)
  datePosted   String          @default("")

  concept      String          @default("") @db.Text
  hook         String          @default("") @db.Text
  retention    String          @default("") @db.Text
  reward       String          @default("") @db.Text
  script       String          @default("") @db.Text
  rawAnalysis  String          @default("") @db.Text
  lunaConcepts String          @default("") @db.Text

  savedToKnowledge Boolean     @default(false)
  knowledgeId      String?
  starred          Boolean     @default(false)

  createdAt   DateTime         @default(now())

  @@index([competitorId])
  @@index([views])
  @@index([createdAt])
}

// ─── LP Assets & Social Proof Gallery ───────────────────
// LpAsset: slots fixos de imagem (1 imagem por chave) por LP.
// Permite swap de foto sem redeploy. Fallback pro arquivo em /public/
// se nenhum registro existir pra aquela (lpSlug, key).
model LpAsset {
  id        String   @id @default(uuid())
  lpSlug    String   // "emagreca-sem-dieta" | "instagram" | etc.
  key       String   // "hero.woman" | "hero.phone" | "avatar.ana" | "mockup.spread"
  imageUrl  String   // URL pública no R2
  alt       String   @default("")
  width     Int?
  height    Int?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([lpSlug, key])
  @@index([lpSlug])
}

// Galeria rotativa da LP: 3 linhas, múltiplos itens por linha.
// kind: photo | whatsapp | testimonial
model SocialProofItem {
  id         String   @id @default(uuid())
  lpSlug     String   // "emagreca-sem-dieta"
  row        Int      // 1 | 2 | 3
  imageUrl   String   // URL pública no R2
  alt        String   @default("")
  caption    String?
  kind       String   @default("photo")
  orderIndex Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lpSlug, active, row, orderIndex])
}
