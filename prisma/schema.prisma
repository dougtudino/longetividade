generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                    String    @id @default(uuid())
  email                 String
  name                  String
  phone                 String?
  plan                  String    // "basico" | "completo" | "vip"
  amount                Int       // em centavos
  status                String    @default("pending") // pending | approved | refunded | canceled | chargeback
  mpPaymentId           String?   @unique
  mpPreferenceId        String?   @unique
  hotmartTransactionId  String?   @unique // ID Hotmart (HP...) — source of truth
  downloadToken         String?   @unique
  downloadCount         Int       @default(0)
  tokenExpiresAt        DateTime?
  syncedFromApiAt       DateTime? // quando foi reconciliada via Hotmart Sales API
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([downloadToken])
  @@index([createdAt])
}

model AbandonedCheckout {
  id        String   @id @default(uuid())
  email     String
  plan      String?
  step      String   @default("checkout")
  createdAt DateTime @default(now())

  @@index([email])
}

model Lead {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  source       String?   // utm_source
  sequenceStep Int       @default(0) // 0=welcome enviado, 1=D+2 enviado, 2=D+5 enviado, -1=opt-out
  lastEmailAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sequenceStep])
  @@index([createdAt])
}

// ─── Creatives — Collections & Gallery ─────────────────

model CreativeCollection {
  id          String     @id @default(uuid())
  slug        String     @unique
  name        String
  description String?
  icon        String?    // emoji
  campaignId  String?    // opcional: liga a uma Campaign local
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  creatives   Creative[]

  @@index([createdAt])
}

model Creative {
  id           String    @id @default(uuid())
  collectionId String
  slug         String    // identificador unico dentro da colecao (ex: "feed-dor")
  componentKey String    // mapeia para CREATIVES_REGISTRY (registry.ts)
  name         String
  format       String    // "feed" | "story" | "banner" | "custom"
  width        Int
  height       Int
  description  String?
  tags         String[]  @default([])
  metaImageHash String?  // hash da imagem na Meta /adimages (se uploaded)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  collection   CreativeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, slug])
  @@index([collectionId])
  @@index([format])
}

// ─── Social Media — Posts & Calendar ───────────────────

model SocialPost {
  id           String    @id @default(uuid())
  title        String
  content      String    @db.Text // copy/legenda do post
  platform     String    // "instagram" | "facebook" | "stories" | "reels" | "tiktok"
  format       String    // "carrossel" | "imagem" | "reels" | "stories" | "texto"
  pillar       String    // "s" | "e" | "m" | "promo"
  hashtags     String?   @db.Text
  imageUrl     String?   // URL do criativo (se tiver)
  imageBriefing String?  @db.Text // briefing pra Uma criar o visual
  slot         String    @default("FEED_AM") // FEED_AM | REEL | STORY — slot de conteudo
  status       String    @default("draft") // draft | review | approved | posted | rejected
  reviewNote   String?   // nota do QA
  scheduledAt  DateTime? // quando postar
  postedAt     DateTime?
  engagementData Json?   // { likes, comments, shares, reach, saves }
  createdBy    String?   // admin que criou
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  images       SocialPostImage[]

  @@index([status])
  @@index([platform])
  @@index([pillar])
  @@index([slot])
  @@index([scheduledAt])
  @@index([createdAt])
}

// PNGs renderizados de cada post/slide. Servidos via rota publica
// /api/public/social-image/[postId]/[slide].png pra Meta Graph buscar.
model SocialPostImage {
  id         String     @id @default(uuid())
  postId     String
  slideIndex Int        @default(0) // 0 = unica/cover; 1,2,3... = carrossel
  mimeType   String     @default("image/png")
  data       Bytes
  width      Int?
  height     Int?
  createdAt  DateTime   @default(now())
  post       SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, slideIndex])
  @@index([postId])
}

// ─── AIOX Agents — Knowledge & Decisions ───────────────

model AgentKnowledge {
  id        String   @id @default(uuid())
  agentId   String   // "gaia" | "maya" | "uma" | "alex" | ...
  kind      String   // "fact" | "rule" | "benchmark" | "reference" | "learning" | "policy"
  title     String
  body      String   @db.Text
  source    String?  // where it came from (manual, gaia-persona, meta-docs, blog-url, etc)
  metadata  Json?    // optional structured data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([kind])
  @@index([createdAt])
}

model AgentDecision {
  id          String   @id @default(uuid())
  agentId     String   // who proposed
  action      String   // "PAUSE_ADSET" | "DUPLICATE_ADSET" | "INCREASE_BUDGET" | "DECREASE_BUDGET" | "ACTIVATE_ADSET"
  targetType  String   // "adset" | "campaign" | "ad" | "creative"
  targetId    String   // Meta ID
  targetName  String   // human-readable
  params      Json     // action params (e.g. { budget_cents: 3600, reason: "..." })
  reasoning   String   @db.Text
  priority    String   @default("normal") // "low" | "normal" | "high" | "critical"
  status      String   @default("proposed") // "proposed" | "approved" | "executed" | "rejected" | "failed"
  approvedBy  String?  // admin email who approved
  approvedAt  DateTime?
  executedAt  DateTime?
  executionResult Json?
  rejectedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id              String    @id @default(uuid())
  name            String
  platform        String    // "meta" | "google" | "organic" | "email"
  objective       String    // "conversao" | "trafego" | "awareness"
  status          String    @default("active") // active | paused | finished
  budget          Float     // orçamento diário R$
  startDate       DateTime
  endDate         DateTime?
  notes           String?
  metaCampaignId  String?   @unique // ID da campanha no Meta (act_xxx/campaigns)
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  metrics         CampaignMetric[]
}

model CampaignMetric {
  id          String   @id @default(uuid())
  campaignId  String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model PageView {
  id           String   @id @default(uuid())
  page         String
  referrer     String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  country      String?
  device       String?
  createdAt    DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([utm_source])
}

// ─── App VIP ───────────────────────────────────────

model AppUser {
  id           String   @id @default(uuid())
  email        String   @unique
  orderId      String   @unique
  plan         String   // "vip"
  accessType   String   @default("lifetime") // "lifetime" | "subscription"
  passwordHash String?  // bcrypt hash (null se login via email-only ou Google)
  googleId     String?  @unique // Google sub ID para OAuth
  createdAt    DateTime @default(now())

  profile         AppProfile?
  checkins        AppCheckin[]
  waterLogs       AppWaterLog[]
  weightLogs      AppWeightLog[]
  moodLogs        AppMoodLog[]
  achievements    AppUserAchievement[]
  level           AppUserLevel?
  favoriteRecipes AppFavoriteRecipe[]
  challenges      AppChallenge[]
  measurements    AppMeasurement[]

  @@index([email])
}

model AppProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  name           String
  objective      String   // "emagrecer" | "habitos" | "ambos"
  currentWeight  Float?
  height         Float?
  age            Int?
  goalType       String   // "primeiro_kg" | "5kg" | "10kg" | "peso_ideal" | "custom"
  goalCustom     String?
  goalWeight     Float?
  challenges     String[]
  onboardingDone Boolean  @default(false)
  waterGoal      Int      @default(8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           AppUser  @relation(fields: [userId], references: [id])
}

model AppCheckin {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  habits       Json     // { agua: bool, refeicoes: bool, fruta: bool, ... }
  waterCount   Int      @default(0)
  exerciseDone Boolean  @default(false)
  exerciseMin  Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  user         AppUser  @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AppWaterLog {
  id       String   @id @default(uuid())
  userId   String
  cups     Int
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppWeightLog {
  id       String   @id @default(uuid())
  userId   String
  weight   Float
  note     String?
  loggedAt DateTime @default(now())

  user     AppUser  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppVipSlot {
  id         String   @id @default("singleton")
  totalSlots Int      @default(100)
  usedSlots  Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── App VIP Sprint 2 ─────────────────────────────

model AppMoodLog {
  id        String   @id @default(uuid())
  userId    String
  mood      String
  note      String?
  triggers  String[]
  loggedAt  DateTime @default(now())
  user      AppUser  @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([loggedAt])
}

model AppAchievement {
  id               String   @id
  name             String
  description      String
  icon             String
  category         String
  condition        String
  xp               Int      @default(10)
  userAchievements AppUserAchievement[]
}

model AppUserAchievement {
  id            String         @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime       @default(now())
  user          AppUser        @relation(fields: [userId], references: [id])
  achievement   AppAchievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@index([userId])
}

model AppUserLevel {
  id        String   @id @default(uuid())
  userId    String   @unique
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
  user      AppUser  @relation(fields: [userId], references: [id])
}

model AppRecipe {
  id          String   @id @default(uuid())
  name        String
  category    String
  pillar      String
  prepTime    Int
  serves      Int
  ingredients String[]
  steps       String[]
  tip         String
  createdAt   DateTime @default(now())
  favorites   AppFavoriteRecipe[]
}

model AppFavoriteRecipe {
  id        String    @id @default(uuid())
  userId    String
  recipeId  String
  createdAt DateTime  @default(now())
  user      AppUser   @relation(fields: [userId], references: [id])
  recipe    AppRecipe @relation(fields: [recipeId], references: [id])
  @@unique([userId, recipeId])
}

model AppChallenge {
  id          String   @id @default(uuid())
  userId      String
  day         Int
  completedAt DateTime @default(now())
  user        AppUser  @relation(fields: [userId], references: [id])
  @@unique([userId, day])
  @@index([userId])
}

model AppMeasurement {
  id        String   @id @default(uuid())
  userId    String
  waist     Float?
  hip       Float?
  note      String?
  loggedAt  DateTime @default(now())
  user      AppUser  @relation(fields: [userId], references: [id])
  @@index([userId])
}

// ─── Admin Multi-User ─────────────────────────────

model AdminUser {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  passwordHash String
  googleId     String?       @unique // Google sub ID para OAuth
  role         String        @default("manager")
  inviteToken  String?       @unique
  inviteUsed   Boolean       @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  mayaMessages MayaMessage[]
}

model MayaMessage {
  id        String    @id @default(uuid())
  adminId   String
  role      String
  content   String    @db.Text
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id])
  @@index([adminId])
  @@index([createdAt])
}
